+            // Leaf start - optimize eye block position
+            final int blockX = this.blockPosition.getX();
+            final int blockZ = this.blockPosition.getZ();
+            final int blockY = Mth.floor(eyeY);
+            final Level level = this.level();
+            FluidState fluidState = level.getFluidStateIfLoadedUnchecked(blockX, blockY, blockZ);
+            if (fluidState == null) { fluidState = level.getFluidState(new BlockPos(blockX, blockY, blockZ)); }
+            final double d = fluidState.isEmpty() ? blockY : blockY + fluidState.getHeight(level, new BlockPos(blockX, blockY, blockZ));
+            // Leaf end - optimize eye block position
             if (d > eyeY) {
                 // Leaf start - Optimize isEyeInFluid
                 this.isInWaterOrLava = fluidState.isEmpty() ? 0 : fluidState.is(FluidTags.WATER) ? 1 : 2;
@@ -2277,22 +2277,25 @@ public abstract class Entity implements SyncedDataHolder, DebugValueSource, Name
         }
     }
 
+    // Leaf start - optimize eye block position
     @Deprecated
     public float getLightLevelDependentMagicValue() {
-        return this.getLightLevelDependentMagicValue(BlockPos.containing(this.getX(), this.getEyeY(), this.getZ())); // Gale - JettPack - optimize sun burn tick - allow passing BlockPos to getLightLevelDependentMagicValue
+        final Level level = this.level();
+        final int blockX = this.blockPosition.getX();
+        final int blockZ = this.blockPosition.getZ();
+        return level.hasChunkAt(blockX, blockZ)
+            ? level.getLightLevelDependentMagicValue(new BlockPos(blockX, Mth.floor(this.getEyeY()), blockZ))

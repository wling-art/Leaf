diff --git a/net/minecraft/world/entity/LivingEntity.java b/net/minecraft/world/entity/LivingEntity.java
index 67e2d911be8ed5fd67bf33441fd1e28b98cef6bc..0d14b344bd6f89d115dc0c396c99502a58109542 100644
--- a/net/minecraft/world/entity/LivingEntity.java
+++ b/net/minecraft/world/entity/LivingEntity.java
@@ -471,7 +471,7 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
             }
 
             if (this.isEyeInWater() // Leaf - Optimize isEyeInFluid
-                && !serverLevel1.getBlockState(BlockPos.containing(this.getX(), this.getEyeY(), this.getZ())).is(Blocks.BUBBLE_COLUMN)) {
+                && !isEyeInBubbleColumn(serverLevel1)) { // Leaf - optimize eye block position
                 boolean flag1 = !this.canBreatheUnderwater()
                     && !MobEffectUtil.hasWaterBreathing(this)
                     && (!flag || !((Player)this).getAbilities().invulnerable);
@@ -539,6 +539,19 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
         profilerFiller.pop();
     }
 
+    // Leaf start - optimize eye block position
+    private boolean isEyeInBubbleColumn(ServerLevel level) {
+        final int x = this.blockPosition.getX();
+        final int z = this.blockPosition.getZ();
+        final int y = Mth.floor(this.getEyeY());
+        BlockState blockState = level.getBlockStateIfLoadedUnchecked(x, y, z);
+        if (blockState == null) {
+            blockState = level.getBlockState(new BlockPos(x, y, z));
+        }
+        return blockState.is(Blocks.BUBBLE_COLUMN);
+    }
+    // Leaf end - optimize eye block position
+
     protected boolean shouldTakeDrowningDamage() {
         return this.getAirSupply() <= -this.level().purpurConfig.drowningDamageInterval; // Purpur - Drowning Settings
     }

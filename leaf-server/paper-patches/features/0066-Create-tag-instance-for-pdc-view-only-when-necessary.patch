From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Dreeam <61569423+Dreeam-qwq@users.noreply.github.com>
Date: Fri, 24 Apr 2026 11:17:23 -0400
Subject: [PATCH] Create tag instance for pdc view only when necessary


diff --git a/src/main/java/org/bukkit/craftbukkit/inventory/CraftItemStack.java b/src/main/java/org/bukkit/craftbukkit/inventory/CraftItemStack.java
index ad0754b239b62f2377ab55f142b76f9ed14c3d59..2d61cf03d1ac121dc6542d38adf9217e915adfac 100644
--- a/src/main/java/org/bukkit/craftbukkit/inventory/CraftItemStack.java
+++ b/src/main/java/org/bukkit/craftbukkit/inventory/CraftItemStack.java
@@ -493,13 +493,11 @@ public final class CraftItemStack extends ItemStack {
 
     public static final String PDC_CUSTOM_DATA_KEY = "PublicBukkitValues";
     private net.minecraft.nbt.CompoundTag getPdcTag() {
-        if (this.handle == null) {
-            return new net.minecraft.nbt.CompoundTag();
-        }
+        if (this.handle == null) return null; // Leaf - Create tag instance for pdc view only when necessary
         final net.minecraft.world.item.component.CustomData customData = this.handle.getOrDefault(DataComponents.CUSTOM_DATA, net.minecraft.world.item.component.CustomData.EMPTY);
         // getUnsafe is OK here because we are only ever *reading* the data so immutability is preserved
         //noinspection deprecation
-        return customData.getUnsafe().getCompoundOrEmpty(PDC_CUSTOM_DATA_KEY);
+        return customData.getUnsafe().getCompound(PDC_CUSTOM_DATA_KEY).orElse(null); // Leaf - Create tag instance for pdc view only when necessary
     }
 
     private static final org.bukkit.craftbukkit.persistence.CraftPersistentDataTypeRegistry REGISTRY = new org.bukkit.craftbukkit.persistence.CraftPersistentDataTypeRegistry();
@@ -507,17 +505,26 @@ public final class CraftItemStack extends ItemStack {
 
         @Override
         public int getSize() {
-            return CraftItemStack.this.getPdcTag().size();
+            // Leaf start - Create tag instance for pdc view only when necessary
+            final CompoundTag tag = CraftItemStack.this.getPdcTag();
+            return tag != null ? tag.size() : 0;
+            // Leaf end - Create tag instance for pdc view only when necessary
         }
 
         @Override
         public net.minecraft.nbt.CompoundTag toTagCompound() {
-            return CraftItemStack.this.getPdcTag();
+            // Leaf start - Create tag instance for pdc view only when necessary
+            final CompoundTag tag = CraftItemStack.this.getPdcTag();
+            return tag != null ? tag : new CompoundTag();
+            // Leaf end - Create tag instance for pdc view only when necessary
         }
 
         @Override
         public net.minecraft.nbt.Tag getTag(final String key) {
-            return CraftItemStack.this.getPdcTag().get(key);
+            // Leaf start - Create tag instance for pdc view only when necessary
+            final CompoundTag tag = CraftItemStack.this.getPdcTag();
+            return tag != null ? tag.get(key) : null;
+            // Leaf end - Create tag instance for pdc view only when necessary
         }
     };
     @Override

From: OverwriteMC <artyom030803@gmail.com>
Date: Sat, 28 Feb 2026 14:17:02 +0900
Subject: [PATCH] Optimize pushable selector

Avoid duplicated Bukkit#isPushable check, already checked inside the Bukkit#canCollideWithBukkit

diff --git a/net/minecraft/world/entity/EntitySelector.java b/net/minecraft/world/entity/EntitySelector.java
index 53a7312bc021edfe46b589d68e3bc775fdda0ffb..9526f091bdde7f91a8e1d437e8faaecbeec63bf1 100644
--- a/net/minecraft/world/entity/EntitySelector.java
+++ b/net/minecraft/world/entity/EntitySelector.java
@@ -49,9 +49,8 @@ public final class EntitySelector {
         Team.CollisionRule ownCollisionRule = ownTeam == null ? Team.CollisionRule.ALWAYS : ownTeam.getCollisionRule();
         return ownCollisionRule == Team.CollisionRule.NEVER
             ? Predicates.alwaysFalse()
-            : NO_SPECTATORS.and(
-                input -> {
-                    if (!input.isPushable() || !input.canCollideWithBukkit(entity) || !entity.canCollideWithBukkit(input)) { // CraftBukkit - collidable API // Paper - Climbing should not bypass cramming gamerule
+            : input -> { // Leaf - optimize pushable selector
+                    if (input.isSpectator() /*|| !pushedEntity.isPushable()*/ || !input.canCollideWithBukkit(entity) || !entity.canCollideWithBukkit(input)) { // CraftBukkit - collidable API // Paper - Climbing should not bypass cramming gamerule // Leaf - optimize pushable selector
                         return false;
                     }
 
@@ -71,8 +70,7 @@ public final class EntitySelector {
                     } else {
                         return false;
                     }
-                }
-            );
+                }; // Leaf - optimize pushable selector
     }
 
     public static Predicate<Entity> notRiding(final Entity entity) {

From: Taiyou06 <kaandindar21@gmail.com>
Date: Sat, 10 May 2025 23:18:17 +0200
Subject: [PATCH] Optimise player movement checks


diff --git a/net/minecraft/world/entity/Entity.java b/net/minecraft/world/entity/Entity.java
index 391bae984cf9603e26fee1566b561ad7ef1770d5..e50cafc07beb73dd61e3b3924efe2ae1452f4084 100644
--- a/net/minecraft/world/entity/Entity.java
+++ b/net/minecraft/world/entity/Entity.java
@@ -1243,7 +1243,7 @@ public abstract class Entity
             }
             // Paper end
 
-            delta = this.maybeBackOffFromEdge(delta, moverType);
+            if (!org.dreeam.leaf.config.modules.opt.OptimizePlayerMovementProcessing.enabled) delta = this.maybeBackOffFromEdge(delta, moverType); // Leaf - Optimise player movement checks
             Vec3 movement = this.collide(delta);
             double movementLength = movement.lengthSqr();
             if (movementLength > 1.0E-7 || delta.lengthSqr() - movementLength < 1.0E-7) {

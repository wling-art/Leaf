     }
 
     public boolean matchingSlot(final EquipmentSlot slot) {
-        return this.definition.slots().stream().anyMatch(group -> group.test(slot));
+        // Leaf start - Remove stream in matchingSlot
+        for (EquipmentSlotGroup group : this.definition.slots()) {
+            if (group.test(slot)) {
+                return true;
+            }
+        }
+        return false;
+        // Leaf end - Remove stream in matchingSlot
     }
 

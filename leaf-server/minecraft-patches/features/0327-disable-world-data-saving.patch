         if (doFull) {
             org.bukkit.Bukkit.getPluginManager().callEvent(new org.bukkit.event.world.WorldSaveEvent(this.getWorld()));
         }
@@ -1739,6 +1740,18 @@ public class ServerLevel extends Level implements ServerEntityGetter, WorldGenLe

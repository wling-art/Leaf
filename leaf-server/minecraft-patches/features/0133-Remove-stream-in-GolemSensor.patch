From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: HaHaWTH <102713261+HaHaWTH@users.noreply.github.com>
Date: Tue, 9 Nov 2077 00:00:00 +0800
Subject: [PATCH] Remove stream in GolemSensor

Stream operations in GolemSensor is really expensive and takes
up 80% time per method call.
Before: 192ms
After: 17ms

diff --git a/net/minecraft/world/entity/ai/sensing/GolemSensor.java b/net/minecraft/world/entity/ai/sensing/GolemSensor.java
index 730b372e46d75e43a553b49dad41cc2d2f7510ee..fb1e4bc5e3a3f42e8f9a1d20df3a2e0215a1871f 100644
--- a/net/minecraft/world/entity/ai/sensing/GolemSensor.java
+++ b/net/minecraft/world/entity/ai/sensing/GolemSensor.java
@@ -33,7 +33,15 @@ public class GolemSensor extends Sensor<LivingEntity> {
     public static void checkForNearbyGolem(final LivingEntity body) {
         Optional<List<LivingEntity>> livingEntitiesMemory = body.getBrain().getMemory(MemoryModuleType.NEAREST_LIVING_ENTITIES);
         if (!livingEntitiesMemory.isEmpty()) {
-            boolean golemPresent = livingEntitiesMemory.get().stream().anyMatch(entity -> entity.is(EntityType.IRON_GOLEM));
+            // Leaf start - Remove stream in GolemSensor
+            boolean golemPresent = false;
+            for (LivingEntity entity : livingEntitiesMemory.get()) {
+                if (entity.is(EntityType.IRON_GOLEM)) {
+                    golemPresent = true;
+                    break;
+                }
+            }
+            // Leaf end - Remove stream in GolemSensor
             if (golemPresent) {
                 golemDetected(body);
             }

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Taiyou06 <kaandindar21@gmail.com>
Date: Thu, 14 Nov 2024 19:54:22 +0800
Subject: [PATCH] Reduce fluid status allocation in NoiseBasedChunkGenerator


diff --git a/net/minecraft/world/level/levelgen/NoiseBasedChunkGenerator.java b/net/minecraft/world/level/levelgen/NoiseBasedChunkGenerator.java
index 8ea44652345f3676d351919eff80697bc1f6af0f..4664b4978b3546609db5b6075ad5e3dc12e6c43d 100644
--- a/net/minecraft/world/level/levelgen/NoiseBasedChunkGenerator.java
+++ b/net/minecraft/world/level/levelgen/NoiseBasedChunkGenerator.java
@@ -68,15 +68,12 @@ public final class NoiseBasedChunkGenerator extends ChunkGenerator {
     }
 
     private static Aquifer.FluidPicker createFluidPicker(final NoiseGeneratorSettings settings) {
-        Aquifer.FluidStatus lavaStatus = new Aquifer.FluidStatus(-54, Blocks.LAVA.defaultBlockState());
-        int seaLevel = settings.seaLevel();
-        Aquifer.FluidStatus seaStatus = new Aquifer.FluidStatus(seaLevel, settings.defaultFluid());
-        Aquifer.FluidStatus emptyStatus = new Aquifer.FluidStatus(DimensionType.MIN_Y * 2, Blocks.AIR.defaultBlockState());
         return (x, y, z) -> {
             if (SharedConstants.DEBUG_DISABLE_FLUID_GENERATION) {
-                return emptyStatus;
+                return new Aquifer.FluidStatus(DimensionType.MIN_Y * 2, Blocks.AIR.defaultBlockState()); // Leaf - Reduce fluid status allocation in NoiseBasedChunkGenerator
             } else {
-                return y < Math.min(-54, seaLevel) ? lavaStatus : seaStatus;
+                int seaLevel = settings.seaLevel(); // Leaf - Reduce fluid status allocation in NoiseBasedChunkGenerator
+                return y < Math.min(-54, seaLevel) ? new Aquifer.FluidStatus(-54, Blocks.LAVA.defaultBlockState()) : new Aquifer.FluidStatus(seaLevel, settings.defaultFluid()); // Leaf - Reduce fluid status allocation in NoiseBasedChunkGenerator
             }
         };
     }

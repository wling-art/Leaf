diff --git a/net/minecraft/server/MinecraftServer.java b/net/minecraft/server/MinecraftServer.java
index 42976696cd85fb74154014da7deae639340e860c..d42e2c284bae645843fd45606094a9dd551255a7 100644
--- a/net/minecraft/server/MinecraftServer.java
+++ b/net/minecraft/server/MinecraftServer.java
@@ -1407,7 +1407,7 @@ public abstract class MinecraftServer extends ReentrantBlockableEventLoop<TickTa
 
                 // Paper - improve tick loop - done above
 
-                try (Profiler.Scope ignored = Profiler.use(this.createProfiler())) {
+                try (Profiler.Scope ignored = org.dreeam.leaf.util.LeafConstants.DISABLE_VANILLA_PROFILER ? null : Profiler.use(this.createProfiler())) { // Leaf - Configurable vanilla profiler
                     this.processPacketsAndTick(sprinting);
                     ProfilerFiller profiler = Profiler.get();
                     profiler.push("nextTickWait");
diff --git a/net/minecraft/server/ReloadableServerResources.java b/net/minecraft/server/ReloadableServerResources.java
index 936266c6c943d799e58b0b06b591d091d540a783..285f651d5363eef4d81eb0a3dc3c6d7283134506 100644
--- a/net/minecraft/server/ReloadableServerResources.java
+++ b/net/minecraft/server/ReloadableServerResources.java
@@ -115,7 +115,7 @@ public class ReloadableServerResources {
                                     backgroundExecutor,
                                     mainThreadExecutor,
                                     DATA_RELOAD_INITIAL_TASK,
-                                    LOGGER.isDebugEnabled()
+                                    !org.dreeam.leaf.util.LeafConstants.DISABLE_VANILLA_PROFILER // Leaf - Configurable vanilla profiler
                                 )
                                 .done()
                                 .thenApply(ignore -> result);
diff --git a/net/minecraft/server/commands/DebugCommand.java b/net/minecraft/server/commands/DebugCommand.java
index e890128286c825ac5fb1ab22dd4a5f61bcced024..e543a4bfd67b2a2ed4ed06285525f21587670f05 100644
--- a/net/minecraft/server/commands/DebugCommand.java
+++ b/net/minecraft/server/commands/DebugCommand.java
@@ -71,6 +71,7 @@ public class DebugCommand {
     }
 
     private static int start(final CommandSourceStack source) throws CommandSyntaxException {
+        if (showRemovalWarning(source, "debug start")) return 0; // Leaf - Configurable vanilla profiler
         MinecraftServer server = source.getServer();
         if (server.isTimeProfilerRunning()) {
             throw ERROR_ALREADY_RUNNING.create();
@@ -82,6 +83,7 @@ public class DebugCommand {
     }
 
     private static int stop(final CommandSourceStack source) throws CommandSyntaxException {
+        if (showRemovalWarning(source, "debug stop")) return 0; // Leaf - Configurable vanilla profiler
         MinecraftServer server = source.getServer();
         if (!server.isTimeProfilerRunning()) {
             throw ERROR_NOT_RUNNING.create();
@@ -99,6 +101,21 @@ public class DebugCommand {
         return (int)tps;
     }
 
+    // Leaf start - Configurable vanilla profiler
+    public static boolean showRemovalWarning(final CommandSourceStack source, final String command) {
+        if (org.dreeam.leaf.util.LeafConstants.DISABLE_VANILLA_PROFILER) {
+            net.kyori.adventure.text.minimessage.MiniMessage mm = net.kyori.adventure.text.minimessage.MiniMessage.miniMessage();
+
+            source.getSender().sendMessage(mm.deserialize("<gold>/" + command + " command is unavailable, since Minecraft's vanilla profiler has been disabled."));
+            source.getSender().sendMessage(mm.deserialize("<gold>Please use <click:suggest_command:'/spark'><grey>/spark</grey></click> instead, or check Leaf docs for more information:"));
+            source.getSender().sendMessage(mm.deserialize("<gold><click:open_url:'" + org.dreeam.leaf.util.LeafConstants.DISABLE_VANILLA_PROFILER_DOCS_URL + "'>" + org.dreeam.leaf.util.LeafConstants.DISABLE_VANILLA_PROFILER_DOCS_URL + "</click>"));
+
+            return true;
+        }
+        return false;
+    }
+    // Leaf end - Configurable vanilla profiler
+
     private static class TraceCustomExecutor
         extends CustomCommandExecutor.WithErrorHandling<CommandSourceStack>
         implements CustomCommandExecutor.CommandAdapter<CommandSourceStack> {
diff --git a/net/minecraft/server/commands/PerfCommand.java b/net/minecraft/server/commands/PerfCommand.java
index f881d6c20487569c0408fbb33e5d9d09363d7cbc..767c812271672271123446265b6ee75f2725ae88 100644
--- a/net/minecraft/server/commands/PerfCommand.java
+++ b/net/minecraft/server/commands/PerfCommand.java
@@ -42,6 +42,7 @@ public class PerfCommand {
     }
 
     private static int startProfilingDedicatedServer(final CommandSourceStack source) throws CommandSyntaxException {
+        if (net.minecraft.server.commands.DebugCommand.showRemovalWarning(source, "perf start")) return 0; // Leaf - Configurable vanilla profiler
         MinecraftServer server = source.getServer();
         if (server.isRecordingMetrics()) {
             throw ERROR_ALREADY_RUNNING.create();
@@ -55,6 +56,7 @@ public class PerfCommand {
     }
 
     private static int stopProfilingDedicatedServer(final CommandSourceStack source) throws CommandSyntaxException {
+        if (net.minecraft.server.commands.DebugCommand.showRemovalWarning(source, "perf stop")) return 0; // Leaf - Configurable vanilla profiler
         MinecraftServer server = source.getServer();
         if (!server.isRecordingMetrics()) {
             throw ERROR_NOT_RUNNING.create();
diff --git a/net/minecraft/server/packs/resources/ReloadableResourceManager.java b/net/minecraft/server/packs/resources/ReloadableResourceManager.java
index f715438dbf6777720661aefcbd316395ed67b21a..5adc89ce571b9e1514c94a21d12ef4a53bee0c26 100644
--- a/net/minecraft/server/packs/resources/ReloadableResourceManager.java
+++ b/net/minecraft/server/packs/resources/ReloadableResourceManager.java
@@ -46,7 +46,7 @@ public class ReloadableResourceManager implements AutoCloseable, ResourceManager
         LOGGER.info("Reloading ResourceManager: {}", LogUtils.defer(() -> resourcePacks.stream().map(PackResources::packId).collect(Collectors.joining(", "))));
         this.resources.close();
         this.resources = new MultiPackResourceManager(this.type, resourcePacks);
-        return SimpleReloadInstance.create(this.resources, this.listeners, backgroundExecutor, mainThreadExecutor, initialTask, LOGGER.isDebugEnabled());
+        return SimpleReloadInstance.create(this.resources, this.listeners, backgroundExecutor, mainThreadExecutor, initialTask, !org.dreeam.leaf.util.LeafConstants.DISABLE_VANILLA_PROFILER); // Leaf - Configurable vanilla profiler
     }
 
     @Override
diff --git a/net/minecraft/util/profiling/Profiler.java b/net/minecraft/util/profiling/Profiler.java
index ee9794784a53cbe4ec02ec4ad94923ce8381b5dd..3465382276faa5f2a96029e3fc168b23f5d514ae 100644
--- a/net/minecraft/util/profiling/Profiler.java
+++ b/net/minecraft/util/profiling/Profiler.java
@@ -45,6 +45,7 @@ public final class Profiler {
     }
 
     public static ProfilerFiller get() {
+        if (org.dreeam.leaf.util.LeafConstants.DISABLE_VANILLA_PROFILER) return InactiveProfiler.INSTANCE; // Leaf - Configurable vanilla profiler
         return ACTIVE_COUNT.get() == 0 ? getDefaultFiller() : Objects.requireNonNullElseGet(ACTIVE.get(), Profiler::getDefaultFiller);
     }
 

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: hayanesuru <hayanesuru@outlook.jp>
Date: Tue, 3 Jun 2025 15:20:40 +0900
Subject: [PATCH] cache biome for mob spawning and advancements


diff --git a/net/minecraft/advancements/criterion/LocationPredicate.java b/net/minecraft/advancements/criterion/LocationPredicate.java
index 8a44bf8036c3efffa3f7c2608cf4dcc8e56d78c3..defad01206f957506813a54cd2c449d4c91fe808 100644
--- a/net/minecraft/advancements/criterion/LocationPredicate.java
+++ b/net/minecraft/advancements/criterion/LocationPredicate.java
@@ -52,7 +52,7 @@ public record LocationPredicate(
 
         BlockPos pos = BlockPos.containing(x, y, z);
         boolean loaded = level.isLoaded(pos);
-        return (!this.biomes.isPresent() || loaded && this.biomes.get().contains(level.getBiome(pos)))
+        return (!this.biomes.isPresent() || loaded && this.biomes.get().contains(org.dreeam.leaf.config.modules.opt.OptimizeBiome.advancement ? level.getBiomeCached(null, pos) : level.getBiome(pos))) // Leaf - cache getBiome
             && (!this.structures.isPresent() || loaded && level.structureManager().getStructureWithPieceAt(pos, this.structures.get()).isValid())
             && (!this.smokey.isPresent() || loaded && this.smokey.get() == CampfireBlock.isSmokeyPos(level, pos))
             && (!this.light.isPresent() || this.light.get().matches(level, pos))
diff --git a/net/minecraft/world/level/LevelReader.java b/net/minecraft/world/level/LevelReader.java

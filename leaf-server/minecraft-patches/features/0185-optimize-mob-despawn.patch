From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: hayanesuru <hayanesuru@outlook.jp>
Date: Fri, 4 Jul 2025 03:22:38 +0900
Subject: [PATCH] optimize mob despawn


diff --git a/net/minecraft/server/level/ServerLevel.java b/net/minecraft/server/level/ServerLevel.java
index 1dab29bf8cb4c7e8f2e53dbb12ad2780a737af69..3cddcc40b25fdd89e3816f8fc6878e495597da65 100644
--- a/net/minecraft/server/level/ServerLevel.java
+++ b/net/minecraft/server/level/ServerLevel.java
@@ -890,6 +890,7 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
             }
 
             io.papermc.paper.entity.activation.ActivationRange.activateEntities(this); // Paper - EAR
+            boolean didDespawn = tickRateManager.runsNormally() && despawnMap.tick(this, this.entityTickList); // Leaf - optimize despawn
             this.entityTickList
                 .forEach(
                     entity -> {
@@ -897,7 +898,7 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
                         if (!entity.isRemoved()) {
                             if (!tickRateManager.isEntityFrozen(entity)) {
                                 profiler.push("checkDespawn");
-                                entity.checkDespawn();
+                                if (!didDespawn) entity.checkDespawn(); // Leaf - optimize despawn
                                 profiler.pop();
                                 if (true) { // Paper - rewrite chunk system
                                     Entity vehicle = entity.getVehicle();
@@ -1032,6 +1033,7 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
     }
     // Paper end - optimise random ticking
 
+    private final org.dreeam.leaf.world.DespawnMap despawnMap = new org.dreeam.leaf.world.DespawnMap(); // Leaf - optimize despawn
     public void tickChunk(final LevelChunk chunk, final int tickSpeed) {
         final net.minecraft.world.level.levelgen.BitRandomSource simpleRandom = this.simpleRandom; // Paper - optimise random ticking // Leaf - Faster random generator - upcasting
         ChunkPos chunkPos = chunk.getPos();

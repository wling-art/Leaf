From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: hayanesuru <hayanesuru@outlook.jp>
Date: Thu, 19 Mar 2026 20:11:58 +0900
Subject: [PATCH] reduce enchantment allocations

reduce allocation of creating entity loot contexts and unmodifiable set boxing

diff --git a/net/minecraft/world/item/enchantment/Enchantment.java b/net/minecraft/world/item/enchantment/Enchantment.java
index 9c4158e134d321653e596d398ed8444e19e570a4..c7263a6fe6968c72b894d92bbe21a4c7a85dae54 100644
--- a/net/minecraft/world/item/enchantment/Enchantment.java
+++ b/net/minecraft/world/item/enchantment/Enchantment.java
@@ -199,9 +199,15 @@ public record Enchantment(Component description, Enchantment.EnchantmentDefiniti
     }
 
     public boolean isImmuneToDamage(final ServerLevel serverLevel, final int enchantmentLevel, final Entity victim, final DamageSource source) {
+        // Leaf start - reduce enchantment allocations
+        List<ConditionalEffect<DamageImmunity>> damageImmunityEffects = this.getEffects(EnchantmentEffectComponents.DAMAGE_IMMUNITY);
+        if (damageImmunityEffects.isEmpty()) {
+            return false;
+        }
+        // Leaf end - reduce enchantment allocations
         LootContext context = damageContext(serverLevel, enchantmentLevel, victim, source);
 
-        for (ConditionalEffect<DamageImmunity> filteredEffect : this.getEffects(EnchantmentEffectComponents.DAMAGE_IMMUNITY)) {
+        for (ConditionalEffect<DamageImmunity> filteredEffect : damageImmunityEffects) { // Leaf - reduce enchantment allocations
             if (filteredEffect.matches(context)) {
                 return true;
             }
@@ -403,8 +409,14 @@ public record Enchantment(Component description, Enchantment.EnchantmentDefiniti
     }
 
     public void tick(final ServerLevel serverLevel, final int enchantmentLevel, final EnchantedItemInUse item, final Entity entity) {
+        // Leaf start - reduce enchantment allocations
+        List<ConditionalEffect<EnchantmentEntityEffect>> tickEffects = this.getEffects(EnchantmentEffectComponents.TICK);
+        if (tickEffects.isEmpty()) {
+            return;
+        }
         applyEffects(
-            this.getEffects(EnchantmentEffectComponents.TICK),
+            tickEffects,
+        // Leaf end - reduce enchantment allocations
             entityContext(serverLevel, enchantmentLevel, entity, entity.position()),
             e -> e.apply(serverLevel, enchantmentLevel, item, entity, entity.position())
         );
diff --git a/net/minecraft/world/item/enchantment/EnchantmentHelper.java b/net/minecraft/world/item/enchantment/EnchantmentHelper.java
index 10be004c98d608327c18fb07c3e9d114f60b2d21..8ae0b521e1483f6b304ac16762e3770d77890d97 100644
--- a/net/minecraft/world/item/enchantment/EnchantmentHelper.java
+++ b/net/minecraft/world/item/enchantment/EnchantmentHelper.java
@@ -133,7 +133,7 @@ public class EnchantmentHelper {
     private static void runIterationOnItem(final ItemStack piece, final EnchantmentHelper.EnchantmentVisitor method) {
         ItemEnchantments enchantments = piece.getOrDefault(DataComponents.ENCHANTMENTS, ItemEnchantments.EMPTY);
 
-        for (Entry<Holder<Enchantment>> entry : enchantments.entrySet()) {
+        for (Entry<Holder<Enchantment>> entry : enchantments.leaf$entrySet()) { // Leaf - reduce enchantment allocations
             method.accept(entry.getKey(), entry.getIntValue());
         }
     }
@@ -146,7 +146,7 @@ public class EnchantmentHelper {
             if (itemEnchantments != null && !itemEnchantments.isEmpty()) {
                 EnchantedItemInUse itemInUse = new EnchantedItemInUse(piece, slot, owner);
 
-                for (Entry<Holder<Enchantment>> entry : itemEnchantments.entrySet()) {
+                for (Entry<Holder<Enchantment>> entry : itemEnchantments.leaf$entrySet()) { // Leaf - reduce enchantment allocations
                     Holder<Enchantment> enchantment = entry.getKey();
                     if (enchantment.value().matchingSlot(slot)) {
                         method.accept(enchantment, entry.getIntValue(), itemInUse);
diff --git a/net/minecraft/world/item/enchantment/ItemEnchantments.java b/net/minecraft/world/item/enchantment/ItemEnchantments.java
index 9260e1c53da0c0e9c3650508c6c92bbf55336b3d..9a058c3a172c25ecacbc165f6be92a20470d993c 100644
--- a/net/minecraft/world/item/enchantment/ItemEnchantments.java
+++ b/net/minecraft/world/item/enchantment/ItemEnchantments.java
@@ -101,6 +101,12 @@ public class ItemEnchantments implements TooltipProvider {
         return Collections.unmodifiableSet(this.enchantments.object2IntEntrySet());
     }
 
+    // Leaf start - reduce enchantment allocations
+    public it.unimi.dsi.fastutil.objects.ObjectSortedSet<Entry<Holder<Enchantment>>> leaf$entrySet() {
+        return this.enchantments.object2IntEntrySet();
+    }
+    // Leaf end - reduce enchantment allocations
+
     public int size() {
         return this.enchantments.size();
     }

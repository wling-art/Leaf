+    // Leaf start - async chunk sender
+    public static void sendChunk(final ServerGamePacketListenerImpl connection, final ServerLevel level, final LevelChunk chunk, final org.dreeam.leaf.async.chunk.AsyncChunkSender chunkSender) {
+        final boolean shouldModify = level.chunkPacketBlockController.shouldModify(connection.player, chunk);
+        net.minecraft.world.level.block.entity.BlockEntity[] blockEntities = chunk.blockEntities.values().toArray(new net.minecraft.world.level.block.entity.BlockEntity[0]);
+        java.util.Map<net.minecraft.world.level.levelgen.Heightmap.Types, long[]> heightmaps = new java.util.EnumMap<>(net.minecraft.world.level.levelgen.Heightmap.Types.class);
+        for (java.util.Map.Entry<net.minecraft.world.level.levelgen.Heightmap.Types, net.minecraft.world.level.levelgen.Heightmap> map : chunk.getHeightmaps()) {
+            if (map.getKey().sendToClient()) {
+                heightmaps.put(map.getKey(), map.getValue().getRawData().clone());
+            }
+        }
+        chunkSender.submit(
+            () -> new ClientboundLevelChunkWithLightPacket(chunk, level.getLightEngine(), null, null, shouldModify, blockEntities, heightmaps)
+        );
+    }
+    // Leaf end - async chunk sender
+

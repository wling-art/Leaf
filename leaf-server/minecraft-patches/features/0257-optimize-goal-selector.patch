+        // Leaf start - optimize goal selector
+        for (int i = 0; i < elemSize; i++) {
+            final WrappedGoal goal = elements[i];
+            if (goal.isRunning() && ((disabled & goal.goal.getFlags().getBackingSet()) != 0 || !goal.canContinueToUse())) {

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Pascalpex <pascalpex@gmail.com>
Date: Wed, 4 Jun 2025 17:03:32 +0200
Subject: [PATCH] Add BlockExplosionHitEvent


diff --git a/net/minecraft/world/level/ServerExplosion.java b/net/minecraft/world/level/ServerExplosion.java
index be97308736a54c8415f1b32f66c42afe8e0e5b4f..92cdd1dbf1a9e1d24399afec0931ab8e77565920 100644
--- a/net/minecraft/world/level/ServerExplosion.java
+++ b/net/minecraft/world/level/ServerExplosion.java
@@ -602,7 +602,11 @@ public class ServerExplosion implements Explosion {
             }
             // CraftBukkit end
 
-            this.level.getBlockState(pos).onExplosionHit(this.level, pos, this, (stackx, position) -> addOrAppendStack(stacks, stackx, position));
+            // Leaf start - Add BlockExplosionHitEvent
+            if (org.dreeam.leaf.event.BlockExplosionHitEvent.getHandlerList().getRegisteredListeners().length == 0 || new org.dreeam.leaf.event.BlockExplosionHitEvent(org.bukkit.craftbukkit.util.CraftLocation.toBukkit(pos, this.level.getWorld()).getBlock(), this.source == null ? null : this.source.getBukkitEntity(), org.bukkit.craftbukkit.CraftExplosionResult.toExplosionResult(this.blockInteraction)).callEvent()) {
+                this.level.getBlockState(pos).onExplosionHit(this.level, pos, this, (stackx, position) -> addOrAppendStack(stacks, stackx, position));
+            }
+            // Leaf end - Add BlockExplosionHitEvent
         }
 
         for (ServerExplosion.StackCollector stack : stacks) {

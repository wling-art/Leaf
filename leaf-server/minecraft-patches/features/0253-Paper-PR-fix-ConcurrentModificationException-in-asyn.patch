From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Gero <gecam59@gmail.com>
Date: Wed, 11 Feb 2026 12:54:45 +0100
Subject: [PATCH] Paper PR: fix ConcurrentModificationException in async
 command sending

Original license: GPL-3.0-only
Original project: https://github.com/PaperMC/Paper
Paper pull request: https://github.com/PaperMC/Paper/pull/13626

fixes ConcurrentModificationException in async command sending (issue https://github.com/PaperMC/Paper/issues/11101)
the CME was caused by map.put(this.dispatcher.getRoot(), rootCommandNode); iterating the roots children asynchronously for hash code calculation. this is fixed by copying the whole root node.

different approach to https://github.com/PaperMC/Paper/pull/13233 without locking/synchronization

diff --git a/net/minecraft/commands/Commands.java b/net/minecraft/commands/Commands.java
index 76a3b97d9f7a03a0670868ce8262749632f603aa..4b8db13709d40bbd8463e704eac482876b50b722 100644
--- a/net/minecraft/commands/Commands.java
+++ b/net/minecraft/commands/Commands.java
@@ -469,10 +469,12 @@ public class Commands {
         // Paper end - Send empty commands if tab completion is disabled
         // CraftBukkit start
         // Register Vanilla commands into builtRoot as before
-        // Paper start - Perf: Async command map building
-        // Copy root children to avoid concurrent modification during building
-        final java.util.Collection<CommandNode<CommandSourceStack>> commandNodes = new java.util.ArrayList<>(this.dispatcher.getRoot().getChildren());
-        COMMAND_SENDING_POOL.execute(() -> this.sendAsync(player, commandNodes));
+        // Paper PR start - fix ConcurrentModificationException in async command sending
+        // Copy root node to avoid concurrent modification during building
+        final RootCommandNode<CommandSourceStack> rootNode = new RootCommandNode<>();
+        this.dispatcher.getRoot().getChildren().forEach(rootNode::addChild);
+        COMMAND_SENDING_POOL.execute(() -> this.sendAsync(player, rootNode));
+        // Paper PR end - fix ConcurrentModificationException in async command sending
     }
 
     // Fixed pool, but with discard policy
@@ -486,12 +488,14 @@ public class Commands {
         new java.util.concurrent.ThreadPoolExecutor.DiscardPolicy()
     );
 
-    private void sendAsync(ServerPlayer player, java.util.Collection<CommandNode<CommandSourceStack>> dispatcherRootChildren) {
+    private void sendAsync(ServerPlayer player, RootCommandNode<CommandSourceStack> dispatcherRoot) { // Paper PR - fix ConcurrentModificationException in async command sending
         // Paper end - Perf: Async command map building
         Map<CommandNode<CommandSourceStack>, CommandNode<CommandSourceStack>> playerCommands = new HashMap<>();
         RootCommandNode<CommandSourceStack> root = new RootCommandNode<>();
-        playerCommands.put(this.dispatcher.getRoot(), root);
-        fillUsableCommands(dispatcherRootChildren, root, player.createCommandSourceStack(), playerCommands); // Paper - Perf: Async command map building; pass copy of children
+        // Paper PR start - fix ConcurrentModificationException in async command sending - pass copy of root
+        playerCommands.put(dispatcherRoot, root);
+        fillUsableCommands(dispatcherRoot, root, player.createCommandSourceStack(), playerCommands);
+        // Paper PR end - fix ConcurrentModificationException in async command sending - pass copy of root
 
         java.util.Collection<String> bukkit = new java.util.LinkedHashSet<>();
         for (CommandNode node : root.getChildren()) {
@@ -523,9 +527,9 @@ public class Commands {
     }
 
     private static <S> void fillUsableCommands(
-        final java.util.Collection<CommandNode<S>> children, final CommandNode<S> target, final S commandFilter, final Map<CommandNode<S>, CommandNode<S>> converted // Paper - Perf: Async command map building; pass copy of children
+        final CommandNode<S> root, final CommandNode<S> target, final S commandFilter, final Map<CommandNode<S>, CommandNode<S>> converted  // Paper PR - fix ConcurrentModificationException in async command sending
     ) {
-        for (CommandNode<S> child : children) { // Paper - Perf: Async command map building; pass copy of children
+        for (CommandNode<S> child : root.getChildren()) { // Paper PR - fix ConcurrentModificationException in async command sending
             // Paper start - Brigadier API
             if (child.clientNode != null) {
                 child = child.clientNode;
@@ -577,7 +581,7 @@ public class Commands {
                 converted.put(child, node);
                 target.addChild(node);
                 if (!child.getChildren().isEmpty()) {
-                    fillUsableCommands(child.getChildren(), node, commandFilter, converted); // Paper - Perf: Async command map building; pass copy of children
+                    fillUsableCommands(child, node, commandFilter, converted); // Paper PR - fix ConcurrentModificationException in async command sending
                 }
             }
         }

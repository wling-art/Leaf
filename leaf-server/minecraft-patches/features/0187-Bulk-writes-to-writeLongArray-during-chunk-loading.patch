From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Taiyou06 <kaandindar21@gmail.com>
Date: Fri, 21 Feb 2025 15:06:55 +0100
Subject: [PATCH] Bulk writes to writeLongArray during chunk loading


diff --git a/net/minecraft/network/FriendlyByteBuf.java b/net/minecraft/network/FriendlyByteBuf.java
index 12cd230ebe97dab655f8546948f06b93f0babf1f..0d1f2ea282d8d1916102b27849771ae69fb6204a 100644
--- a/net/minecraft/network/FriendlyByteBuf.java
+++ b/net/minecraft/network/FriendlyByteBuf.java
@@ -347,7 +347,7 @@ public class FriendlyByteBuf extends ByteBuf {
     }
 
     public FriendlyByteBuf writeLongArray(final long[] longs) {
-        writeLongArray(this, longs);
+        writeLongArrayBulk(this, longs); // Leaf - Bulk writes to writeLongArray during chunk loading
         return this;
     }
 
@@ -357,7 +357,7 @@ public class FriendlyByteBuf extends ByteBuf {
     }
 
     public FriendlyByteBuf writeFixedSizeLongArray(final long[] longs) {
-        writeFixedSizeLongArray(this, longs);
+        writeFixedSizeLongArrayBulk(this, longs); // Leaf - Bulk writes to writeLongArray during chunk loading
         return this;
     }
 
@@ -367,6 +367,50 @@ public class FriendlyByteBuf extends ByteBuf {
         }
     }
 
+    // Leaf start - Bulk writes to writeLongArray during chunk loading
+    private static void writeLongArrayBulk(final FriendlyByteBuf output, final long[] longs) {
+        VarInt.write(output, longs.length);
+        writeFixedSizeLongArrayBulk(output, longs);
+    }
+
+    private static void writeFixedSizeLongArrayBulk(final FriendlyByteBuf output, final long[] longs) {
+        if (longs.length == 0) {
+            return;
+        }
+        int neededBytes = longs.length * Long.BYTES;
+        int maxWritableBytes = output.source.maxWritableBytes();
+
+        if (maxWritableBytes >= neededBytes) {
+            output.source.ensureWritable(neededBytes);
+            int writerIndex = output.source.writerIndex();
+
+            if (output.source.hasArray()) {
+                byte[] dest = output.source.array();
+                int offset = output.source.arrayOffset() + writerIndex;
+
+                ByteBuffer buf = ByteBuffer.wrap(dest, offset, neededBytes).order(output.source.order());
+                buf.asLongBuffer().put(longs);
+                output.source.writerIndex(writerIndex + neededBytes);
+            } else if (output.source.nioBufferCount() > 0) {
+                ByteBuffer nioBuf = output.source.nioBuffer(writerIndex, neededBytes);
+                nioBuf.asLongBuffer().put(longs);
+                output.source.writerIndex(writerIndex + neededBytes);
+            } else {
+                ByteBuffer temp = ByteBuffer.allocate(neededBytes).order(output.source.order());
+                temp.asLongBuffer().put(longs);
+                temp.rewind();
+                output.source.writeBytes(temp);
+            }
+        } else {
+            // Not enough space even at max capacity, use traditional approach
+            // which will write each element individually (and handle growing the buffer as needed)
+            for (long l : longs) {
+                output.writeLong(l);
+            }
+        }
+    }
+    // Leaf end - Bulk writes to writeLongArray during chunk loading
+
     public long[] readLongArray() {
         return readLongArray(this);
     }

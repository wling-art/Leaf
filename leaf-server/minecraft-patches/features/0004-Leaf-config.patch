diff --git a/net/minecraft/server/Main.java b/net/minecraft/server/Main.java
index eb45a226c1b4d09e6e58114b5b3cf2db95a7d14b..bfb15b5d60eb3b625323a0ce22cc66ef4e7af923 100644
--- a/net/minecraft/server/Main.java
+++ b/net/minecraft/server/Main.java
@@ -99,6 +99,8 @@ public class Main {
                 writePidFile(pidFilePath);
             }
 
+            org.dreeam.leaf.config.LeafConfig.loadConfig(); // Leaf - Leaf config
+
             CrashReport.preload();
             if (options.has("jfrProfile")) { // CraftBukkit
                 JvmProfiler.INSTANCE.start(Environment.SERVER);
@@ -115,6 +117,7 @@ public class Main {
             Bootstrap.bootStrap();
             Bootstrap.validate();
             Util.startTimerHackThread();
+            org.dreeam.leaf.config.ConfigModules.loadAfterBootstrap(); // Leaf - Leaf config - post load
             Path settingsFile = Paths.get("server.properties");
             DedicatedServerSettings settings = new DedicatedServerSettings(options); // CraftBukkit - CLI argument support
             settings.forceSave();

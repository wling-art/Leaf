diff --git a/net/minecraft/server/network/ServerLoginPacketListenerImpl.java b/net/minecraft/server/network/ServerLoginPacketListenerImpl.java
index b9276c15bc48c9ecb21128776deb7f96b5d87c0e..875fb1360350c3b182758fa64d9ddecd6db4b3c3 100644
--- a/net/minecraft/server/network/ServerLoginPacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerLoginPacketListenerImpl.java
@@ -186,7 +186,10 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
         if (singleplayerProfile != null && this.requestedUsername.equalsIgnoreCase(singleplayerProfile.name())) {
             this.startClientVerification(singleplayerProfile);
         } else {
-            if (this.server.usesAuthentication() && !this.connection.isMemoryConnection()) {
+            // Leaf start - pre authenticate event
+            boolean shouldAuthenticate = new org.dreeam.leaf.event.AsyncPreAuthenticateEvent(requestedUsername, requestedUuid, connection.getRemoteAddress(), !server.usesAuthentication()).callEvent();
+            if (shouldAuthenticate && !this.connection.isMemoryConnection()) {
+                // Leaf end - pre authenticate event
                 this.state = ServerLoginPacketListenerImpl.State.KEY;
                 this.connection.send(new ClientboundHelloPacket("", this.server.getKeyPair().getPublic().getEncoded(), this.challenge, true));
             } else {

diff --git a/net/minecraft/world/entity/ai/targeting/TargetingConditions.java b/net/minecraft/world/entity/ai/targeting/TargetingConditions.java
index a80812af1cae93d930722ada75be2f167fcb7fc9..a3d270f323d4d5bea09f3e502ad814ffda500c27 100644
--- a/net/minecraft/world/entity/ai/targeting/TargetingConditions.java
+++ b/net/minecraft/world/entity/ai/targeting/TargetingConditions.java
@@ -83,9 +83,17 @@ public class TargetingConditions {
             }
 
             if (this.range > 0.0) {
-                double modifier = this.testInvisible ? target.getVisibilityPercent(targeter) : 1.0;
-                double visibilityDistance = Math.max(this.range * modifier, 2.0);
                 double distanceToSqr = targeter.distanceToSqr(target.getX(), target.getY(), target.getZ());
+                // Gale start - Airplane - check targeting range before getting visibility
+                double followRangeRaw = this.range;
+
+                if (distanceToSqr > followRangeRaw * followRangeRaw) { // the actual follow range will always be this value or smaller, so if the distance is larger then it never will return true after getting invis
+                    return false;
+                }
+
+                double modifier = this.testInvisible ? target.getVisibilityPercent(targeter) : 1.0;
+                double visibilityDistance = Math.max(followRangeRaw * modifier, 2.0);
+                // Gale end - Airplane - check targeting range before getting visibility
                 if (distanceToSqr > visibilityDistance * visibilityDistance) {
                     return false;
                 }

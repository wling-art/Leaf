From: HaHaWTH <102713261+HaHaWTH@users.noreply.github.com>
Date: Fri, 29 Oct 2077 00:00:00 +0800
Subject: [PATCH] Optimize Entity distanceToSqr

This patch optimizes Entity#distanceToSqr call by using Math#fma which is around 1.2x to 4x faster than original method,
avoids multiple casting in Entity#distanceTo, using Math#sqrt directly instead of Mojang's Mth#sqrt. Additionally, this patch makes
these methods more able to be inlined by the JIT compiler.

diff --git a/net/minecraft/world/entity/Entity.java b/net/minecraft/world/entity/Entity.java
index 811c9c6cbc6534e16f0680c9f430ef025f7b2745..da30a2d4530bab2557d80564dce0fe163325b275 100644
--- a/net/minecraft/world/entity/Entity.java
+++ b/net/minecraft/world/entity/Entity.java
@@ -2363,31 +2363,6 @@ public abstract class Entity
         return new Vec3(this.xOld, this.yOld, this.zOld);
     }
 
-    public float distanceTo(final Entity entity) {
-        float xd = (float)(this.getX() - entity.getX());
-        float yd = (float)(this.getY() - entity.getY());
-        float zd = (float)(this.getZ() - entity.getZ());
-        return Mth.sqrt(xd * xd + yd * yd + zd * zd);
-    }
-
-    public double distanceToSqr(final double x2, final double y2, final double z2) {
-        double xd = this.getX() - x2;
-        double yd = this.getY() - y2;
-        double zd = this.getZ() - z2;
-        return xd * xd + yd * yd + zd * zd;
-    }
-
-    public double distanceToSqr(final Entity entity) {
-        return this.distanceToSqr(entity.position());
-    }
-
-    public double distanceToSqr(final Vec3 pos) {
-        double xd = this.getX() - pos.x;
-        double yd = this.getY() - pos.y;
-        double zd = this.getZ() - pos.z;
-        return xd * xd + yd * yd + zd * zd;
-    }
-
     public void playerTouch(final Player player) {
     }
 
@@ -5544,4 +5519,34 @@ public abstract class Entity
         return false;
     }
     // Purpur end - Ridables
+
+    // Leaf start - Optimize Entity distanceTo
+    // Inlining and avoid casting
+    // Use Math#sqrt instead of Mojang's Mth#sqrt - only cast once
+    // Added option to enable FMA acceleration
+    public final float distanceTo(final Entity entity) {
+        final double dx = this.getX() - entity.getX();
+        final double dy = this.getY() - entity.getY();
+        final double dz = this.getZ() - entity.getZ();
+        return (float) Math.sqrt(org.dreeam.leaf.util.LeafConstants.ENABLE_FMA ? Math.fma(dx, dx, Math.fma(dy, dy, dz * dz)) : dx * dx + dy * dy + dz * dz);
+    }
+
+    public final double distanceToSqr(final double x, final double y, final double z) {
+        final double dx = this.getX() - x;
+        final double dy = this.getY() - y;
+        final double dz = this.getZ() - z;
+        return org.dreeam.leaf.util.LeafConstants.ENABLE_FMA ? Math.fma(dx, dx, Math.fma(dy, dy, dz * dz)) : dx * dx + dy * dy + dz * dz;
+    }
+
+    public final double distanceToSqr(final Vec3 pos) {
+        final double dx = this.getX() - pos.x;
+        final double dy = this.getY() - pos.y;
+        final double dz = this.getZ() - pos.z;
+        return org.dreeam.leaf.util.LeafConstants.ENABLE_FMA ? Math.fma(dx, dx, Math.fma(dy, dy, dz * dz)) : dx * dx + dy * dy + dz * dz;
+    }
+
+    public double distanceToSqr(final Entity entity) {
+        return this.distanceToSqr(entity.position());
+    }
+    // Leaf end - Optimize Entity distanceToSqr
 }
